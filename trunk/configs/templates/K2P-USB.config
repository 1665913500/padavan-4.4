### 硬件平台信息 (仅支持 Ralink RT3883/MT7620/MT7621/MT7628)
CONFIG_VENDOR=Ralink        # 厂商：Ralink
CONFIG_PRODUCT=MT7621      # 芯片：MT7621
CONFIG_MEM_SIZE=512        # 内存大小：512MB

### 设备产品ID (最多12个字符)
CONFIG_FIRMWARE_PRODUCT_ID="K2P-USB"  # 固件标识：K2P-USB改版

### Linux内核与工具链
CONFIG_FIRMWARE_INCLUDE_SFE=y         # 开启SFE硬件加速 (提升转发性能)
CONFIG_LINUXDIR=linux-4.4.x            # 内核版本：linux-4.4.x

############################################################
### Linux内核配置
############################################################

### 启用IPv6支持
CONFIG_FIRMWARE_ENABLE_IPV6=y          # 开启IPv6

### 启用USB支持
CONFIG_FIRMWARE_ENABLE_USB=y           # 开启USB主控驱动

### 使用AVM官方NTFS驱动 (性能比ntfs-3g更好)
CONFIG_FIRMWARE_INCLUDE_ANTFS=y        # 开启ANTFS原生NTFS支持

### 启用FAT/FAT32文件系统支持
CONFIG_FIRMWARE_ENABLE_FAT=y           # 开启FAT32格式支持

### 启用exFAT文件系统支持
CONFIG_FIRMWARE_ENABLE_EXFAT=y         # 开启exFAT格式支持

### 启用EXT2文件系统支持
CONFIG_FIRMWARE_ENABLE_EXT2=y          # 开启EXT2格式支持

### 启用EXT3文件系统支持
CONFIG_FIRMWARE_ENABLE_EXT3=y          # 开启EXT3格式支持

### 启用EXT4文件系统支持 (自动包含EXT3/EXT2)
CONFIG_FIRMWARE_ENABLE_EXT4=y          # 开启EXT4格式支持

### 启用XFS文件系统支持
CONFIG_FIRMWARE_ENABLE_XFS=n           # 关闭XFS (大容量硬盘用，一般不需要)

### 启用FUSE用户态文件系统支持
CONFIG_FIRMWARE_ENABLE_FUSE=y          # 开启FUSE (挂载虚拟文件系统)

### 启用swap交换分区/文件支持
CONFIG_FIRMWARE_ENABLE_SWAP=n          # 关闭虚拟内存swap

### 包含UVC摄像头驱动
#CONFIG_FIRMWARE_INCLUDE_UVC=y         # 注释关闭 USB摄像头

### 包含USB键盘鼠标等HID设备驱动
#CONFIG_FIRMWARE_INCLUDE_HID=y         # 注释关闭 USB外设

### 包含USB串口驱动 (如pl2303)
CONFIG_FIRMWARE_INCLUDE_SERIAL=n       # 关闭USB串口

### 包含USB声卡驱动
#CONFIG_FIRMWARE_INCLUDE_AUDIO=y       # 注释关闭 USB声卡

### 包含IPsec (XFRM) 模块与iptables扩展
CONFIG_FIRMWARE_INCLUDE_XFRM=n         # 关闭IPsec

### 包含网络QoS调度模块
CONFIG_FIRMWARE_INCLUDE_QOS=n          # 关闭QoS流量控制

### 包含IMQ流量整形模块 (轻微降低性能)
CONFIG_FIRMWARE_INCLUDE_IMQ=n          # 关闭IMQ

### 包含IFB流量整形模块
CONFIG_FIRMWARE_INCLUDE_IFB=n          # 关闭IFB

### 包含IPSet工具与内核模块
CONFIG_FIRMWARE_INCLUDE_IPSET=y        # 开启IPSet (防火墙必备)

### 包含NFSv3服务端
CONFIG_FIRMWARE_INCLUDE_NFSD=n         # 关闭NFS服务

### 包含NFSv3客户端
CONFIG_FIRMWARE_INCLUDE_NFSC=n         # 关闭NFS客户端

### 包含CIFS (SMB) 客户端
#CONFIG_FIRMWARE_INCLUDE_CIFS=y        # 注释关闭 SMB客户端

############################################################
### 用户空间应用配置
############################################################

### WebUI多语言 (仅保留中文)
CONFIG_FIRMWARE_INCLUDE_LANG_CN=y      # 开启中文语言包
#CONFIG_FIRMWARE_INCLUDE_LANG_BR=y
#CONFIG_FIRMWARE_INCLUDE_LANG_CZ=y
#CONFIG_FIRMWARE_INCLUDE_LANG_DA=y
#CONFIG_FIRMWARE_INCLUDE_LANG_DE=y
#CONFIG_FIRMWARE_INCLUDE_LANG_ES=y
#CONFIG_FIRMWARE_INCLUDE_LANG_FI=y
#CONFIG_FIRMWARE_INCLUDE_LANG_FR=y
#CONFIG_FIRMWARE_INCLUDE_LANG_NO=y
#CONFIG_FIRMWARE_INCLUDE_LANG_PL=y
#CONFIG_FIRMWARE_INCLUDE_LANG_RU=y
#CONFIG_FIRMWARE_INCLUDE_LANG_SV=y
#CONFIG_FIRMWARE_INCLUDE_LANG_UK=y

### 包含NTFS-3G FUSE驱动
CONFIG_FIRMWARE_INCLUDE_NTFS_3G=n      # 关闭ntfs-3g (已用ANTFS)

### 包含LPR打印机服务
CONFIG_FIRMWARE_INCLUDE_LPRD=y         # 开启USB打印服务

### 包含USB-以太网打印服务
CONFIG_FIRMWARE_INCLUDE_U2EC=y         # 开启网络打印转发

### 包含tcpdump抓包工具
CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y      # 开启抓包工具

### 包含hdparm硬盘管理工具
CONFIG_FIRMWARE_INCLUDE_HDPARM=y       # 开启硬盘休眠/管理工具

### 包含parted分区工具 (支持GPT)
CONFIG_FIRMWARE_INCLUDE_PARTED=y       # 开启硬盘分区工具

### 包含SMB3.6文件共享服务 (含WINS)
CONFIG_FIRMWARE_INCLUDE_SMBD=y         # 开启SAMBA文件共享

### 仅包含WINS服务
CONFIG_FIRMWARE_INCLUDE_WINS=n         # 关闭独立WINS

### 包含SMB/WINS日志服务
CONFIG_FIRMWARE_INCLUDE_SMBD_SYSLOG=n  # 关闭SAMBA日志

### 包含FTP服务
CONFIG_FIRMWARE_INCLUDE_FTPD=y         # 开启FTP文件服务

### 包含RP-L2TP客户端
CONFIG_FIRMWARE_INCLUDE_RPL2TP=n       # 关闭L2TP客户端

### 包含EAP-TTLS/EAP-PEAP企业WiFi认证
CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=y     # 开启企业WiFi认证

### 启用HTTPS后台管理
CONFIG_FIRMWARE_INCLUDE_HTTPS=n         # 关闭HTTPS后台

### 包含SFTP服务
CONFIG_FIRMWARE_INCLUDE_SFTP=y         # 开启SFTP文件传输

### 包含dropbear轻量SSH
CONFIG_FIRMWARE_INCLUDE_DROPBEAR=n     # 关闭轻量SSH

### dropbear加速加密算法
CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=n  # 关闭dropbear加速

### 替换为OpenSSH完整版SSH
CONFIG_FIRMWARE_INCLUDE_OPENSSH=y      # 开启OpenSSH (功能更强)

### 包含OpenVPN
CONFIG_FIRMWARE_INCLUDE_OPENVPN=y      # 开启OpenVPN

### 包含StrongSwan
CONFIG_FIRMWARE_INCLUDE_SSWAN=n        # 关闭StrongSwan

### 为openssl添加椭圆曲线加密
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y   # 开启EC加密算法

### 包含openssl命令行工具 (生成证书)
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=y  # 开启openssl工具

### 包含xUPNPd IPTV媒体服务
CONFIG_FIRMWARE_INCLUDE_XUPNPD=y       # 开启IPTV UPnP

### 包含Minidlna媒体服务
CONFIG_FIRMWARE_INCLUDE_MINIDLNA=n     # 关闭DLNA

### 包含Firefly iTunes媒体服务
CONFIG_FIRMWARE_INCLUDE_FIREFLY=n      # 关闭iTunes服务

### 使用新版ffmpeg
CONFIG_FIRMWARE_INCLUDE_FFMPEG_NEW=y   # 开启新版ffmpeg

### 包含Transmission下载工具
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION=n  # 关闭TR下载

### 包含Transmission网页控制
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION_WEB_CONTROL=n  # 关闭TR网页

### 包含Aria2下载工具
CONFIG_FIRMWARE_INCLUDE_ARIA=y         # 开启Aria2下载

### 包含Aria2网页控制面板
CONFIG_FIRMWARE_INCLUDE_ARIA_WEB_CONTROL=y  # 开启Aria2网页

### 包含curl网络工具
CONFIG_FIRMWARE_INCLUDE_CURL=y         # 开启curl

### 校园网客户端
CONFIG_FIRMWARE_INCLUDE_SCUTCLIENT=n   # 关闭华工客户端
CONFIG_FIRMWARE_INCLUDE_GDUT_DRCOM=n   # 关闭广工DRCOM
CONFIG_FIRMWARE_INCLUDE_DOGCOM=y       # 开启DOGCOM
CONFIG_FIRMWARE_INCLUDE_MINIEAP=y      # 开启MINIEAP
CONFIG_FIRMWARE_INCLUDE_NJIT_CLIENT=y  # 开启NJIT校园网
CONFIG_FIRMWARE_INCLUDE_MENTOHUST=n    # 关闭锐捷

### VPN系列
CONFIG_FIRMWARE_INCLUDE_SOFTETHERVPN_SERVER=n   # 关闭SoftEther服务端
CONFIG_FIRMWARE_INCLUDE_SOFTETHERVPN_CLIENT=n   # 关闭SoftEther客户端
CONFIG_FIRMWARE_INCLUDE_SOFTETHERVPN_CMD=n      # 关闭SoftEther命令行
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y    # 开启WireGuard

### 实用工具
CONFIG_FIRMWARE_INCLUDE_VLMCSD=y       # 开启KMS激活
CONFIG_FIRMWARE_INCLUDE_TTYD=y         # 开启网页终端
CONFIG_FIRMWARE_INCLUDE_LRZSZ=n        # 关闭文件传输
CONFIG_FIRMWARE_INCLUDE_HTOP=y         # 开启进程监控
CONFIG_FIRMWARE_INCLUDE_NANO=y         # 开启文本编辑器
CONFIG_FIRMWARE_INCLUDE_IPERF3=y       # 开启网速测试
CONFIG_FIRMWARE_INCLUDE_DUMP1090=n     # 关闭航空信号
CONFIG_FIRMWARE_INCLUDE_RTL_SDR=n      # 关闭软件无线电
CONFIG_FIRMWARE_INCLUDE_MTR=y          # 开启路由追踪
CONFIG_FIRMWARE_INCLUDE_SOCAT=y        # 开启端口转发
CONFIG_FIRMWARE_INCLUDE_SRELAY=y       # 开启socks代理
CONFIG_FIRMWARE_INCLUDE_FRPC=n         # 关闭内网穿透客户端
CONFIG_FIRMWARE_INCLUDE_FRPS=n         # 关闭内网穿透服务端
